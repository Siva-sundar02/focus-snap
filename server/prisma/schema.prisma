generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String
  expenses  Expense[]
}

model Expense {
  id        Int      @id @default(autoincrement())
  amount    Float
  category  String
  note      String?
  date      DateTime
  userId    Int

  user      User @relation(fields: [userId], references: [id])
}